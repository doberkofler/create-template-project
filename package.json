{
	"name": "create-template-project",
	"version": "0.1.0",
	"type": "module",
	"license": "MIT",
	"author": "Dieter Oberkofler",
	"files": [
		"dist"
	],
	"keywords": [
		"scaffold",
		"template",
		"cli",
		"typescript"
	],
	"bin": {
		"create-template-project": "./dist/index.mjs"
	},
	"scripts": {
		"dev": "tsdown --watch",
		"build": "tsdown",
		"lint": "tsc && oxlint --type-aware --type-check && npm run prettier",
		"prettier": "prettier --check .",
		"prettier-write": "prettier --write .",
		"test": "vitest run --coverage",
		"ci": "npm run lint && npm run build && npm run test",
		"create-changelog": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0",
		"prepare": "husky"
	},
	"main": "./dist/index.mjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": "./dist/index.mjs",
		"./package.json": "./package.json"
	},
	"engines": {
		"node": ">=22"
	},
	"repository": {
		"type": "git",
		"url": "git://github.com/doberkofler/create-template-project.git"
	},
	"homepage": "https://github.com/doberkofler/create-template-project#readme",
	"devDependencies": {
		"@commitlint/cli": "20.4.2",
		"@commitlint/config-conventional": "20.4.2",
		"@types/cli-progress": "3.11.6",
		"@types/debug": "4.1.12",
		"@types/fs-extra": "^11.0.4",
		"@types/node": "25.3.0",
		"@vitest/coverage-v8": "4.0.18",
		"conventional-changelog": "7.1.1",
		"conventional-changelog-angular": "8.1.0",
		"conventional-changelog-cli": "5.0.0",
		"eslint-plugin-regexp": "3.0.0",
		"globals": "17.3.0",
		"husky": "9.1.7",
		"oxlint": "1.50.0",
		"oxlint-tsgolint": "0.15.0",
		"prettier": "3.8.1",
		"tsdown": "0.20.3",
		"typescript": "5.9.3",
		"vitest": "4.0.18"
	},
	"dependencies": {
		"@inquirer/prompts": "^8.3.0",
		"cli-progress": "3.12.0",
		"commander": "14.0.3",
		"debug": "4.4.3",
		"execa": "^9.6.1",
		"fs-extra": "11.3.3",
		"zod": "4.3.6"
	}
}
