{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"plugins": ["unicorn", "typescript", "oxc", "import", "react", "jsdoc", "promise", "vitest"],
	"jsPlugins": ["eslint-plugin-regexp"],
	"categories": {},
	"rules": {
		"constructor-super": "error", // Require `super()` calls in constructors.
		"for-direction": "error", // Enforce "for" loop update clause moving the counter in the right direction.
		"no-async-promise-executor": "error", // Disallow using an async function as a Promise executor.
		"no-caller": "error", // Disallow the use of `arguments.caller` or `arguments.callee`.
		"no-class-assign": "error", // Disallow reassigning class members.
		"no-compare-neg-zero": "error", // Disallow comparing against -0.
		"no-cond-assign": "error", // Disallow assignment operators in conditional expressions.
		"no-const-assign": "error", // Disallow reassigning `const` variables.
		"no-constant-binary-expression": "error", // Disallow expressions where the operation doesn't affect the value.
		"no-constant-condition": "error", // Disallow constant expressions in conditions.
		"no-control-regex": "error", // Disallow control characters in regular expressions.
		"no-debugger": "error", // Disallow the use of `debugger`.
		"no-delete-var": "error", // Disallow deleting variables.
		"no-dupe-class-members": "error", // Disallow duplicate class members.
		"no-dupe-else-if": "error", // Disallow duplicate conditions in if-else-if chains.
		"no-dupe-keys": "error", // Disallow duplicate keys in object literals.
		"no-duplicate-case": "error", // Disallow duplicate case labels.
		"no-empty-character-class": "error", // Disallow empty character classes in regular expressions.
		"no-empty-pattern": "error", // Disallow empty destructuring patterns.
		"no-empty-static-block": "error", // Disallow empty static blocks.
		"no-eval": "error", // Disallow the use of `eval()`.
		"no-ex-assign": "error", // Disallow reassigning exceptions in `catch` clauses.
		"no-extra-boolean-cast": "error", // Disallow unnecessary boolean casts.
		"no-func-assign": "error", // Disallow reassigning function declarations.
		"no-global-assign": "error", // Disallow assignments to native objects or read-only global variables.
		"no-import-assign": "error", // Disallow assigning to imported bindings.
		"no-invalid-regexp": "error", // Disallow invalid regular expression strings in `RegExp` constructors.
		"no-irregular-whitespace": "error", // Disallow irregular whitespace.
		"no-loss-of-precision": "error", // Disallow literal numbers that lose precision.
		"no-new-native-nonconstructor": "error", // Disallow `new` operators with global non-constructor functions.
		"no-nonoctal-decimal-escape": "error", // Disallow \8 and \9 escape sequences in string literals.
		"no-obj-calls": "error", // Disallow calling global object properties as functions.
		"no-self-assign": "error", // Disallow assignments where both sides are exactly the same.
		"no-setter-return": "error", // Disallow returning values from setters.
		"no-shadow-restricted-names": "error", // Disallow identifiers from shadowing restricted names.
		"no-sparse-arrays": "error", // Disallow sparse arrays.
		"no-this-before-super": "error", // Disallow `this`/`super` before calling `super()` in constructors.
		"no-unassigned-vars": "error", // Disallow use of unassigned variables.
		"no-unsafe-finally": "error", // Disallow control flow statements in `finally` blocks.
		"no-unsafe-negation": "error", // Disallow negating the left operand of relational operators.
		"no-unsafe-optional-chaining": "error", // Disallow use of optional chaining in contexts where the undefined value is not allowed.
		"no-unused-expressions": "error", // Disallow unused expressions.
		"no-unused-labels": "error", // Disallow unused labels.
		"no-unused-private-class-members": "error", // Disallow unused private class members.
		"no-useless-backreference": "error", // Disallow useless backreferences in regular expressions.
		"no-useless-catch": "error", // Disallow unnecessary `catch` clauses.
		"no-useless-escape": "error", // Disallow unnecessary escape characters.
		"no-useless-rename": "error", // Disallow renaming import, export, and destructured assignments to the same name.
		"no-with": "error", // Disallow `with` statements.
		"require-yield": "error", // Require generator functions to contain `yield`.
		"use-isnan": "error", // Require calls to `isNaN()` when checking for `NaN`.
		"valid-typeof": "error", // Enforce comparing `typeof` expressions against valid strings.
		"oxc/bad-array-method-on-arguments": "error", // Disallow calling array methods on the `arguments` object.
		"oxc/bad-char-at-comparison": "error", // Disallow bad character comparisons using `charAt`.
		"oxc/bad-comparison-sequence": "error", // Disallow bad comparison sequences.
		"oxc/bad-min-max-func": "error", // Disallow bad `min`/`max` function calls.
		"oxc/bad-object-literal-comparison": "error", // Disallow comparing object literals directly.
		"oxc/bad-replace-all-arg": "error", // Disallow bad arguments in `replaceAll`.
		"oxc/const-comparisons": "error", // Disallow constant comparisons that will always evaluate to true or false.
		"oxc/double-comparisons": "error", // Disallow confusing double comparisons.
		"oxc/erasing-op": "error", // Disallow operations that erase values, like `x * 0`.
		"oxc/missing-throw": "error", // Disallow missing `throw` keyword when instantiating `Error` objects.
		"oxc/number-arg-out-of-range": "error", // Disallow number arguments that are out of range.
		"oxc/only-used-in-recursion": "error", // Disallow variables that are only used in recursion.
		"oxc/uninvoked-array-callback": "error", // Disallow uninvoked callbacks in array methods.
		"typescript/await-thenable": "error", // Disallow awaiting a value that is not a Thenable.
		"typescript/no-array-delete": "error", // Disallow using the delete operator on array values.
		"typescript/no-base-to-string": "error", // Require `.toString()` to only be called on objects which provide useful information.
		"typescript/no-duplicate-enum-values": "error", // Disallow duplicate enum member values.
		"typescript/no-duplicate-type-constituents": "error", // Disallow duplicate constituents of union or intersection types.
		"typescript/no-extra-non-null-assertion": "error", // Disallow extra non-null assertion.
		"typescript/no-floating-promises": "error", // Require Promise-like statements to be handled appropriately.
		"typescript/no-for-in-array": "error", // Disallow iterating over an array with a `for-in` loop.
		"typescript/no-implied-eval": "error", // Disallow the use of `eval()`-like methods.
		"typescript/no-meaningless-void-operator": "error", // Disallow the `void` operator except when used to discard a value.
		"typescript/no-misused-new": "error", // Enforce valid definition of `new` and `constructor`.
		"typescript/no-misused-spread": "error", // Disallow spreading certain object types.
		"typescript/no-non-null-asserted-optional-chain": "error", // Disallow non-null assertions after an optional chain expression.
		"typescript/no-redundant-type-constituents": "error", // Disallow members of unions and intersections that do nothing or override type information.
		"typescript/no-this-alias": "error", // Disallow aliasing `this`.
		"typescript/no-unnecessary-parameter-property-assignment": "error", // Disallow unnecessary parameter property assignments.
		"typescript/no-unsafe-declaration-merging": "error", // Disallow unsafe declaration merging.
		"typescript/no-unsafe-unary-minus": "error", // Disallow the use of the unary minus operator on invalid types.
		"typescript/no-unused-vars": [
			"error",
			{
				"caughtErrors": "none",
				"argsIgnorePattern": "^_"
			}
		], // Disallow unused variables.
		"typescript/no-useless-empty-export": "error", // Disallow empty exports that don't change anything in a module file.
		"typescript/no-wrapper-object-types": "error", // Disallow using String, Number, and Boolean in favor of string, number, and boolean.
		"typescript/prefer-as-const": "error", // Prefer `as const` over literal type.
		"typescript/require-array-sort-compare": "error", // Require `Array#sort` calls to always provide a `compareFunction`.
		"typescript/restrict-template-expressions": "error", // Enforce template literal expressions to be of string type.
		"typescript/triple-slash-reference": "error", // Disallow certain triple slash directives in favor of ES6-style import declarations.
		"typescript/unbound-method": "error", // Enforce unbound methods are called with their expected scope.
		"unicorn/no-await-in-promise-methods": "error", // Disallow using `await` in `Promise` method parameters.
		"unicorn/no-empty-file": "error", // Disallow empty files.
		"unicorn/no-invalid-fetch-options": "error", // Disallow invalid options in `fetch()`.
		"unicorn/no-invalid-remove-event-listener": "error", // Disallow invalid event listener removal.
		"unicorn/no-new-array": "error", // Disallow `new Array()`.
		"unicorn/no-single-promise-in-promise-methods": "error", // Disallow passing single promise to `Promise.all()`/`race()`/`any()`.
		"unicorn/no-thenable": "error", // Disallow `then` property.
		"unicorn/no-unnecessary-await": "error", // Disallow unnecessary `await`.
		"unicorn/no-useless-fallback-in-spread": "error", // Disallow useless fallback when spreading.
		"unicorn/no-useless-length-check": "error", // Disallow useless array length check.
		"unicorn/no-useless-spread": "error", // Disallow useless spread.
		"unicorn/prefer-set-size": "error", // Prefer `Set#size` over `Array#length` when checking for size.
		"unicorn/prefer-string-starts-ends-with": "error", // Prefer `String#startsWith` & `String#endsWith` over more complex alternatives.
		"regexp/confusing-quantifier": "error", // Disallow confusing quantifiers.
		"regexp/control-character-escape": "error", // Disallow control character escape sequences.
		"regexp/match-any": "error", // Disallow match-any characters.
		"regexp/negation": "error", // Disallow negation in regular expressions.
		"regexp/no-contradiction-with-assertion": "error", // Disallow contradictions with assertions.
		"regexp/no-dupe-characters-character-class": "error", // Disallow duplicate characters in character classes.
		"regexp/no-dupe-disjunctions": "error", // Disallow duplicate disjunctions.
		"regexp/no-empty-alternative": "error", // Disallow empty alternatives.
		"regexp/no-empty-capturing-group": "error", // Disallow empty capturing groups.
		"regexp/no-empty-character-class": "error", // Disallow empty character classes.
		"regexp/no-empty-group": "error", // Disallow empty groups.
		"regexp/no-empty-lookarounds-assertion": "error", // Disallow empty lookaround assertions.
		"regexp/no-empty-string-literal": "error", // Disallow empty string literals in Regex.
		"regexp/no-escape-backspace": "error", // Disallow escape backspace.
		"regexp/no-extra-lookaround-assertions": "error", // Disallow extra lookaround assertions.
		"regexp/no-invalid-regexp": "error", // Disallow invalid regular expressions.
		"regexp/no-invisible-character": "error", // Disallow invisible characters.
		"regexp/no-lazy-ends": "error", // Disallow lazy quantifiers at the end of a regular expression.
		"regexp/no-legacy-features": "error", // Disallow legacy RegExp features.
		"regexp/no-misleading-capturing-group": "error", // Disallow misleading capturing groups.
		"regexp/no-misleading-unicode-character": "error", // Disallow misleading Unicode characters.
		"regexp/no-missing-g-flag": "error", // Disallow missing `g` flag in certain operations.
		"regexp/no-non-standard-flag": "error", // Disallow non-standard flags.
		"regexp/no-obscure-range": "error", // Disallow obscure ranges in character classes.
		"regexp/no-optional-assertion": "error", // Disallow optional assertions.
		"regexp/no-potentially-useless-backreference": "error", // Disallow potentially useless backreferences.
		"regexp/no-super-linear-backtracking": "error", // Disallow super-linear backtracking.
		"regexp/no-trivially-nested-assertion": "error", // Disallow trivially nested assertions.
		"regexp/no-trivially-nested-quantifier": "error", // Disallow trivially nested quantifiers.
		"regexp/no-unused-capturing-group": "error", // Disallow unused capturing groups.
		"regexp/no-useless-assertions": "error", // Disallow useless assertions.
		"regexp/no-useless-backreference": "error", // Disallow useless backreferences.
		"regexp/no-useless-character-class": "error", // Disallow useless character classes.
		"regexp/no-useless-dollar-replacements": "error", // Disallow useless dollar replacements in strings.
		"regexp/no-useless-escape": "error", // Disallow useless escape characters.
		"regexp/no-useless-flag": "error", // Disallow useless flags.
		"regexp/no-useless-lazy": "error", // Disallow useless lazy quantifiers.
		"regexp/no-useless-non-capturing-group": "error", // Disallow useless non-capturing groups.
		"regexp/no-useless-quantifier": "error", // Disallow useless quantifiers.
		"regexp/no-useless-range": "error", // Disallow useless ranges.
		"regexp/no-useless-set-operand": "error", // Disallow useless set operands.
		"regexp/no-useless-string-literal": "error", // Disallow useless string literals.
		"regexp/no-useless-two-nums-quantifier": "error", // Disallow useless two numbers quantifiers.
		"regexp/no-zero-quantifier": "error", // Disallow zero quantifiers.
		"regexp/optimal-lookaround-quantifier": "error", // Require optimal lookaround quantifiers.
		"regexp/optimal-quantifier-concatenation": "error", // Require optimal quantifier concatenation.
		"regexp/prefer-character-class": "error", // Prefer character class over logical OR.
		"regexp/prefer-d": "error", // Prefer `\d` over `[0-9]`.
		"regexp/prefer-plus-quantifier": "error", // Prefer `+` over `{1,}`.
		"regexp/prefer-predefined-assertion": "error", // Prefer predefined assertions.
		"regexp/prefer-question-quantifier": "error", // Prefer `?` over `{0,1}`.
		"regexp/prefer-range": "error", // Prefer ranges in character classes.
		"regexp/prefer-set-operation": "error", // Prefer set operations.
		"regexp/prefer-star-quantifier": "error", // Prefer `*` over `{0,}`.
		"regexp/prefer-unicode-codepoint-escapes": "error", // Prefer Unicode codepoint escapes.
		"regexp/prefer-w": "error", // Prefer `\w` over `[a-zA-Z0-9_]`.
		"regexp/simplify-set-operations": "error", // Require simplified set operations.
		"regexp/sort-flags": "error", // Require flags to be sorted.
		"regexp/strict": "error", // Enforce strict mode in regular expressions.
		"regexp/use-ignore-case": "error" // Require the use of the ignore case flag where appropriate.
	},
	"settings": {
		"jsx-a11y": {
			"polymorphicPropName": null,
			"components": {},
			"attributes": {}
		},
		"next": {
			"rootDir": []
		},
		"react": {
			"formComponents": [],
			"linkComponents": [],
			"version": null
		},
		"jsdoc": {
			"ignorePrivate": false,
			"ignoreInternal": false,
			"ignoreReplacesDocs": true,
			"overrideReplacesDocs": true,
			"augmentsExtendsReplacesDocs": false,
			"implementsReplacesDocs": false,
			"exemptDestructuredRootsFromChecks": false,
			"tagNamePreference": {}
		},
		"vitest": {
			"typecheck": false
		}
	},
	"env": {
		"builtin": true
	},
	"globals": {},
	"ignorePatterns": [
		"**/.*", // Ignore all dotfiles
		"node_modules/**", // Ignore node_modules
		"dist/**", // Ignore build output
		"coverage/**", // Ignore coverage reports
		"public/**" // Ignore public assets
	]
}