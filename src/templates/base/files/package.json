{
	"name": "{{projectName}}",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"typecheck": "tsc --noEmit",
		"lint": "oxlint",
		"format": "oxfmt --write",
		"format:check": "oxfmt --check",
		"ci": "npm run typecheck && npm run lint && npm run format:check && npm run build && npm run test",
		"test": "vitest run --coverage",
		"release": "release-it",
		"create-changelog": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0",
		"prepare": "husky"
	},
	"dependencies": {
		"debug": ""
	},
	"devDependencies": {
		"@commitlint/cli": "",
		"@commitlint/config-conventional": "",
		"@types/debug": "",
		"@types/node": "",
		"@vitest/coverage-v8": "",
		"conventional-changelog": "",
		"husky": "",
		"oxlint": "",
		"oxlint-tsgolint": "",
		"oxfmt": "",
		"release-it": "",
		"eslint-plugin-regexp": "",
		"typescript": "",
		"vitest": ""
  }
}
